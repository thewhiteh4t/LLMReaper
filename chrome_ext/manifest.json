{
  "name": "Xentiqo",
  "description": "AI Workflow Assistant",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "js": ["scripts/content.js"],
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ]
    }
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.ngrok-free.app/*",
    "https://*.trycloudflare.com/*"
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  }
}
